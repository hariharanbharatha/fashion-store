pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git url: 'https://github.com/hariharanbharatha/fashion-store.git', branch: 'main'

            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t fashion-store-app .'
            }
        }

        stage('Run Docker Container') {
            steps {
                sh 'docker run -d -p 3000:3000 fashion-store-app'
            }
        }
    }
}
